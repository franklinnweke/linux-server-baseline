# Domain pointing to this server public IP
DOMAIN=n8n.example.com

# Let's Encrypt account email
LETSENCRYPT_EMAIL=you@example.com

# Container image + pinned tag
APP_IMAGE=docker.n8n.io/n8nio/n8n
APP_TAG=1.87.1

# Internal app port used by container and proxy
APP_PORT_INTERNAL=5678

# Server timezone
TZ=UTC
